<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 2rem; border-radius: 16px; margin-bottom: 2rem;">
    <h2>Selamat Datang, <%= user.nama %>! 👋</h2>
    <p>Anda login sebagai <strong><%= user.role %></strong> dengan username <strong><%= user.username %></strong></p>
</div>

<div style="display: flex; gap: 20px; margin: 20px 0;">
    <div style="background: white; padding: 20px; border-radius: 12px; flex: 1; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <h3>Total Peminjaman</h3>
        <p style="font-size: 32px; font-weight: bold; color: #667eea;"><%= riwayat ? riwayat.length : 0 %></p>
    </div>
    <div style="background: white; padding: 20px; border-radius: 12px; flex: 1; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <h3>Sedang Dipinjam</h3>
        <p style="font-size: 32px; font-weight: bold; color: #ed8936;"><%= riwayat ? riwayat.filter(r => r.status === 'dipinjam').length : 0 %></p>
    </div>
    <div style="background: white; padding: 20px; border-radius: 12px; flex: 1; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <h3>Menunggu</h3>
        <p style="font-size: 32px; font-weight: bold; color: #e53e3e;"><%= riwayat ? riwayat.filter(r => r.status === 'menunggu').length : 0 %></p>
    </div>
</div>

<h2>📜 Riwayat Peminjaman Terbaru</h2>

<% if (riwayat && riwayat.length > 0) { %>
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden;">
            <thead>
                <tr style="background: #2c3e50; color: white;">
                    <th style="padding: 12px;">ID</th>
                    <th style="padding: 12px;">Tanggal Pinjam</th>
                    <th style="padding: 12px;">Rencana Kembali</th>
                    <th style="padding: 12px;">Alat</th>
                    <th style="padding: 12px;">Status</th>
                </tr>
            </thead>
            <tbody>
                <% riwayat.slice(0, 5).forEach(r => { %>
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 12px;">#<%= r.id_peminjaman %></td>
                    <td style="padding: 12px;"><%= r.tanggal_pinjam %></td>
                    <td style="padding: 12px;"><%= r.tanggal_rencana_kembali %></td>
                    <td style="padding: 12px;">
                        <% if (r.details && r.details.length > 0) { %>
                            <% r.details.forEach(d => { %>
                                <span style="display: inline-block; background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; margin: 2px;">
                                    <strong><%= d.nama_alat %></strong> x<%= d.jumlah %>
                                </span>
                            <% }) %>
                        <% } else { %>-<% } %>
                    </td>
                    <td style="padding: 12px;">
                        <% if (r.status === 'menunggu') { %>
                            <span style="background: #ed8936; color: white; padding: 4px 12px; border-radius: 20px;">⏳ Menunggu</span>
                        <% } else if (r.status === 'dipinjam') { %>
                            <span style="background: #667eea; color: white; padding: 4px 12px; border-radius: 20px;">📌 Dipinjam</span>
                        <% } else { %>
                            <span style="background: #48bb78; color: white; padding: 4px 12px; border-radius: 20px;">✅ Dikembalikan</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    
    <% if (riwayat.length > 5) { %>
        <div style="margin-top: 15px; text-align: right;">
            <a href="/peminjam/riwayat" style="color: #667eea;">Lihat semua riwayat →</a>
        </div>
    <% } %>
<% } else { %>
    <div style="text-align: center; padding: 40px; background: white; border-radius: 8px;">
        <p>Belum ada riwayat peminjaman.</p>
    </div>
<% } %>

<div style="display: flex; gap: 15px; margin-top: 30px;">
    <a href="/peminjam/alat" style="background: #48bb78; color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px;">🔍 Lihat Daftar Alat</a>
    <a href="/peminjam/pinjam" style="background: #667eea; color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px;">📝 Ajukan Peminjaman</a>
</div>