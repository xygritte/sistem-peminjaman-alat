<div class="dashboard">
    <h1>Dashboard Petugas</h1>
    
    <div style="display: flex; gap: 20px; margin: 20px 0;">
        <div style="background: #ed8936; color: white; padding: 20px; border-radius: 10px; flex: 1;">
            <h3>Menunggu Persetujuan</h3>
            <p style="font-size: 32px; font-weight: bold;"><%= menunggu.length %></p>
        </div>
        <div style="background: #667eea; color: white; padding: 20px; border-radius: 10px; flex: 1;">
            <h3>Sedang Dipinjam</h3>
            <p style="font-size: 32px; font-weight: bold;"><%= dipinjam.length %></p>
        </div>
    </div>
    
    <h2>Peminjaman Menunggu Persetujuan</h2>
    <table style="width: 100%; border-collapse: collapse; margin-top: 10px;">
        <thead>
            <tr style="background: #2c3e50; color: white;">
                <th style="padding: 10px;">ID</th>
                <th style="padding: 10px;">Peminjam</th>
                <th style="padding: 10px;">Tanggal Pinjam</th>
                <th style="padding: 10px;">Aksi</th>
            </tr>
        </thead>
        <tbody>
            <% menunggu.forEach(m => { %>
            <tr style="border-bottom: 1px solid #ddd;">
                <td style="padding: 10px;"><%= m.id_peminjaman %></td>
                <td style="padding: 10px;"><%= m.peminjam_nama %></td>
                <td style="padding: 10px;"><%= m.tanggal_pinjam %></td>
                <td style="padding: 10px;">
                    <a href="/petugas/approve/<%= m.id_peminjaman %>" style="background: #48bb78; color: white; padding: 5px 10px; text-decoration: none; border-radius: 3px;">Setujui</a>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>